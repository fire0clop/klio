# ---- PostgreSQL ----
POSTGRES_USER=klio
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=klio_db
# Async driver. Use host "postgres" with docker-compose, or "localhost" when running locally.
DATABASE_URL=postgresql+asyncpg://klio:CHANGE_ME@postgres:5432/klio_db

# ---- JWT ----
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Anthropic Claude (AI) ----
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# Optional outbound proxy for the Anthropic client: http://user:pass@host:port
ANTHROPIC_PROXY_URL=

# ---- Social auth ----
# Apple: your iOS app bundle ID (used as the audience claim on Apple identity tokens).
APPLE_CLIENT_ID=com.klio.diary
# Google iOS OAuth 2.0 client ID (audience for verifying Google id_tokens).
# Format: 1234567890-abcdefghijklmn.apps.googleusercontent.com  — see SOCIAL_AUTH_SETUP.md
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
